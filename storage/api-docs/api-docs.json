        "/api/transaksi": {
            "post": {
                "tags": [
                    "Transaksi"
                ],
                "summary": "Buat transaksi baru",
                "operationId": "storeTransaksi",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "tanggal",
                                    "jumlah",
                                    "tipe"
                                ],
                                "properties": {
                                    "user_id": {
                                        "description": "Opsional, ID user yang valid",
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "kategori_id": {
                                        "description": "Opsional, ID kategori yang valid",
                                        "type": "integer",
                                        "example": 2
                                    },
                                    "tanggal": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2024-05-05"
                                    },
                                    "jumlah": {
                                        "type": "integer",
                                        "example": 100000
                                    },
                                    "tipe": {
                                        "type": "string",
                                        "enum": [
                                            "Pemasukan",
                                            "Pengeluaran"
                                        ],
                                        "example": "Pemasukan"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Transaksi berhasil dibuat",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validasi gagal",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "message": {
                                            "type": "string",
                                            "example": "The given data was invalid."
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
