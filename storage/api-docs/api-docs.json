                                    "tipe"
                                ],
                                "properties": {
                                    "nama_kategori": {
                                        "type": "string",
                                        "example": "Food"
                                    },
                                    "tipe": {
                                        "type": "string",
                                        "enum": [
                                            "Pemasukan",
                                            "Pengeluaran"
