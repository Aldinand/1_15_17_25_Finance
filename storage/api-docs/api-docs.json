                                        },
                                        "nama_kategori": {
                                            "type": "string"
                                        },
                                        "tipe": {
                                            "type": "string"
                                        },
                                        "user_id": {
                                            "type": "integer"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
